# Copy to .env and fill in. Never commit .env.

# Default LLM provider + API key (used by core agents).
# Override per-agent by setting a model in config/models.yaml.
DHRUBO_LLM__PROVIDER=openai
OPENAI_API_KEY=not-needed
OPENAI_BASE_URL=http://127.0.0.1:1234/v1

# Optional alternative provider
ANTHROPIC_API_KEY=

# Logging level: DEBUG | INFO | WARNING | ERROR
DHRUBO_LOGGING__LEVEL=INFO

# Where run artifacts go
DHRUBO_OUTPUT__DIRECTORY=./output
